generator client {
  provider      = "prisma-client-js"
  // Container runs Debian (node:20-slim) with OpenSSL 3.x. Pin the target so
  // Prisma never falls back to an openssl-1.1.x engine that cannot load libssl.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id           String                 @id @default(cuid())
  name         String
  type         String
  currency     String                 @default("EUR")
  balance      Decimal                @default(0)
  // Balance before the first recorded transaction. Imported history is never
  // complete, so the derived balance is openingBalance + sum(transactions).
  openingBalance Decimal              @default(0)
  color        String                 @default("#6366f1")
  icon         String?
  institution  String?
  iban         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions   Transaction[]          @relation("FromAccount")
  toTransactions Transaction[]          @relation("ToAccount")
  recurring      RecurringTransaction[]
  goals          Goal[]
  holdings       Holding[]
}

// An investment position. Revolut and other brokers expose no API for personal
// accounts, so quantities are entered or imported once; only the price is
// refreshed automatically.
model Holding {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol      String // ticker used for the price lookup, e.g. AAPL or ASML.AS
  name        String?
  quantity    Decimal
  avgCost     Decimal? // per share, in `currency`
  currency    String    @default("USD") // currency the price is quoted in
  lastPrice   Decimal?
  lastPriceAt DateTime?
  trades      Trade[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accountId, symbol])
}

model Trade {
  id        String   @id @default(cuid())
  holdingId String
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  date      DateTime
  kind      String // BUY | SELL
  quantity  Decimal
  price     Decimal? // per share, in the holding currency
  opening   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([holdingId])
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  description  String?
  targetAmount Decimal
  savedAmount  Decimal   @default(0)
  accountId    String?
  account      Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  targetDate   DateTime?
  color        String    @default("#6366f1")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Category {
  id           String                 @id @default(cuid())
  name         String                 @unique
  color        String                 @default("#6366f1")
  icon         String?
  parentId     String?
  parent       Category?              @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]             @relation("SubCategories")
  transactions Transaction[]
  recurring    RecurringTransaction[]
  createdAt    DateTime               @default(now())
}

model Transaction {
  id           String                @id @default(cuid())
  accountId    String
  account      Account               @relation("FromAccount", fields: [accountId], references: [id], onDelete: Cascade)
  toAccountId  String?
  toAccount    Account?              @relation("ToAccount", fields: [toAccountId], references: [id])
  categoryId   String?
  category     Category?             @relation(fields: [categoryId], references: [id])
  amount       Decimal
  description  String
  date         DateTime
  type         String
  notes        String?
  recurringId  String?
  recurring    RecurringTransaction? @relation(fields: [recurringId], references: [id])
  importedFrom String?
  externalId   String?
  // Counterparty IBAN from imported statements; used to detect transfers
  // between two accounts that both exist in FinTrack.
  counterpartyIban String?
  receipts     Receipt[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([externalId, accountId])
}

model Receipt {
  id         String    @id @default(cuid())
  filename   String
  storedName String
  mimeType   String
  size       Int
  // What the vision model read off the image; optional, a poor photo may only
  // yield some of it.
  merchant   String?
  date       DateTime?
  amount     Decimal?
  currency   String?
  kind       String? // RECEIPT | INVOICE | PAYSLIP | UNKNOWN
  rawText    String?
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  status     String    @default("PENDING") // PENDING | MATCHED | CREATED | UNMATCHED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([transactionId])
  @@index([status])
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String?
  email              String?  @unique
  oidcSubject        String?  @unique
  googleOidcSubject  String?  @unique
  role               String   @default("user")
  twoFactorSecret    String?
  twoFactorEnabled   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Settings {
  id                 String   @id @default("singleton")
  passwordHash       String?
  twoFactorSecret    String?
  twoFactorEnabled   Boolean  @default(false)
  jwtSecret          String?
  appPort            Int?
  defaultCurrency    String   @default("EUR")
  appName            String   @default("FinTrack")
  oidcEnabled        Boolean  @default(false)
  oidcTenantId       String?
  oidcClientId       String?
  oidcClientSecret   String?
  googleOidcEnabled  Boolean  @default(false)
  googleClientId     String?
  googleClientSecret String?
  // Local Ollama used to suggest categories and clean up descriptions
  aiUrl              String?
  aiModel            String?
  // Language hint for transaction labelling; empty = treat as multilingual
  aiLanguage         String?
  // How imports handle transfers between two known accounts: off | auto | confirm
  transferDetection  String   @default("confirm")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BackupConfig {
  id         String    @id @default(cuid())
  label      String
  type       String
  enabled    Boolean   @default(true)
  configJson String    @default("{}")
  schedule   String    @default("0 2 * * *")
  lastRunAt  DateTime?
  lastStatus String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model RecurringTransaction {
  id           String        @id @default(cuid())
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?     @relation(fields: [categoryId], references: [id])
  amount       Decimal
  description  String
  type         String
  frequency    String
  startDate    DateTime
  endDate      DateTime?
  nextDate     DateTime
  active       Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
